# Build outputs — generated by Vite/Electron, never commit these
dist/
dist-electron/
out/

# Dependencies — restored by npm install
node_modules/

# Electron builder output
release/

# Environment and secrets — NEVER commit credentials
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IntelliJ / JetBrains IDE files
.idea/
*.iml
*.iws
*.ipr

# TypeScript build info
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# SQLite database — local data, not for version control
*.db
*.db-shm
*.db-wal

