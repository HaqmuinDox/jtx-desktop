{
  "name": "jtx-desktop",
  "description": "Desktop client for Nextcloud Journals, Tasks, and Notes",
  "author": "HaqmuinDox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
